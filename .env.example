# Telegram
TELEGRAM_BOT_TOKEN=123456:ABCDEF
TELEGRAM_WEBHOOK_SECRET=change-this-random-secret-path
OWNER_TELEGRAM_ID=123456789

# Supabase server-side keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Encryption key for refresh tokens.
# Generate: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY_HEX=64_HEX_CHARS

# Optional: protect daily cleanup endpoint
CRON_SECRET=change-this-cleanup-secret

# Limits
MAX_MAIL_PER_USER=100
MAX_IMPORT_PER_BATCH=100
CHECK_COOLDOWN_SECONDS=8
MAX_CHECK_PER_HOUR=30
FETCH_LATEST_MESSAGES=10
MAX_RETURN_MESSAGES_PER_CHECK=3
